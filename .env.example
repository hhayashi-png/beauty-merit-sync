# ビューティーメリット管理画面ログイン情報
BMERIT_LOGIN_ID=your_login_id_here
BMERIT_PASSWORD=your_password_here

# 出力先スプレッドシート(本番値は固定で OK)
SPREADSHEET_ID=1aykK8ll0upbVoJnJJrXBp_cAXBovyI6hc4XzoI8GZ10
SHEET_NAME=予約情報csv

# Google サービスアカウント鍵
# GitHub Actions では JSON 文字列そのもの(Secrets から注入される)
# ローカルでは JSON ファイルのパス(例: ./credentials.json)も受け付ける
# どちらの形式かは自動判別される
GOOGLE_CREDENTIALS_JSON=./credentials.json
# 例: JSON文字列で渡したい場合はこちら
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ローカル開発用: ブラウザを表示して目視デバッグする場合は false
HEADLESS=true
# デバッグ用スクリーンショット/HTMLダンプを常に撮る場合は true
DEBUG_DUMP=false
